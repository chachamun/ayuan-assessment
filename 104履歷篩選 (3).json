      "parameters": {
        "jsCode": "// ===== 1. 取得所有輸入資料 =====\nconst allInputs = $input.all();\nif (allInputs.length === 0) return [];\n\nconst resumeData = $('Code in JavaScript3').first().json || {};\nconst resumeText = resumeData.resumeText || '';\nconst extractedJobTitle = resumeData.jobTitle || '未指定職缺';\n\n// ===== 2. 職缺比對容錯邏輯 =====\nlet jobRow = {};\nconst sheetNode = $(\"Get row(s) in sheet1\");\nconst sheetResults = sheetNode.all();\n\nif (sheetResults.length > 0 && sheetResults[0].json && sheetResults[0].json['職缺類型']) {\n  jobRow = sheetResults[0].json;\n} else {\n  jobRow = {\n    \"職缺內容\": `應徵者投遞職位為：${extractedJobTitle}。請依據一般美妝/製造產業之通用營運、行政與品質規範進行適任性評估。`,\n    \"職缺類型\": \"營運\"\n  };\n}\n\nconst jobContent = jobRow['職缺內容'];\nconst jobType = jobRow['職缺類型'];\n// 讀取評分補充欄位（若存在）\nconst scoringNote = jobRow['評分補充'] ? `\\n【本職缺特別評分重點】\\n${jobRow['評分補充']}` : '';\n\n// ===== 3. 設定職缺權重 =====\nconst weightMap = {\n  '業務': '產業背景25%、技能符合度20%、經驗年資20%、穩定度20%、文化適配度15%',\n  '行銷': '產業背景25%、文化適配度20%、技能符合度20%、經驗年資20%、穩定度15%',\n  '營運': '技能符合度30%、經驗年資25%、穩定度20%、產業背景15%、文化適配度10%'\n};\nconst weights = weightMap[jobType] || weightMap['營運'];\n\n// ===== 4. 建構 Prompt =====\nconst prompt = `你是專業HR招募顧問，用繁體中文分析，執行「經歷交叉查證」（年資重疊、職稱跳躍、技能矛盾）。\n\n【職缺】${jobType}｜${jobContent}${scoringNote}\n\n【履歷】\n${resumeText}\n\n【評分維度】\n1.技能符合度：職缺硬技能與專業知識\n2.經驗年資：核心職位相關經歷深度\n3.產業背景：化妝品/美妝/FMCG/製造業經驗\n4.穩定度：平均每份工作<2年或有不明斷層應扣分\n5.文化適配度：是否符合溫和/專業/細節/友善溝通\n\n【計算規則】\n權重：${weights}\n人才分類：即戰力≥80｜潛力型65-79.99且任一維度≥75｜不建議<65或穩定度<50\n面試建議：✅強烈建議≥85｜🟡可考慮75-84.99｜❌暫不推薦<75\n\n只回傳JSON：\n{\"name\":\"姓名\",\"age\":\"年齡數字或null\",\"career_stage\":\"初階/中階/資深/主管\",\"position\":\"${extractedJobTitle}\",\"job_type\":\"${jobType}\",\"education\":\"最高學歷\",\"experience_years\":\"年資\",\"score_skill\":0,\"score_experience\":0,\"score_industry\":0,\"score_stability\":0,\"score_culture\":0,\"score\":0,\"talent_type\":\"即戰力/潛力型/不建議\",\"interview_suggestion\":\"✅強烈建議/🟡可考慮/❌暫不推薦\",\"highlight_tags\":\"#標籤1 #標籤2 #標籤3\",\"core_skills\":\"核心技能摘要\",\"score_reason\":\"評分理由與加權計算\",\"consistency_check\":\"交叉查證結果或「經查核邏輯正常」\",\"strengths\":\"主要優勢50字內\",\"weaknesses\":\"主要不足50字內\",\"interview_q1\":\"\",\"interview_q2\":\"\",\"interview_q3\":\"\",\"interview_q4\":\"\",\"interview_q5\":\"\"}`;\n\n// ===== 5. 輸出給 HTTP Request 節點 =====\nreturn [{\n  json: {\n    requestBody: JSON.stringify({\n      contents: [{ parts: [{ text: prompt }] }],\n      generationConfig: {\n        temperature: 0.2,\n        response_mime_type: \"application/json\"\n      }\n    })\n  }\n}];"
      },
