      "parameters": {
        "jsCode": "const emails = $input.all();\n\nreturn emails.map(item => {\n  const email = item.json;\n\n  let resumeText = '';\n  let resumeLink = '';\n  let resumeId = '';\n  let phone = '';\n  let emailAddress = '';\n  let jobTitle = '';\n\n  if (email.text && email.text.trim()) {\n    resumeText = email.text.trim();\n  } else if (email.html) {\n    resumeText = email.html\n      .replace(/<style[^>]*>[\\s\\S]*?<\\/style>/gi, '')\n      .replace(/<script[^>]*>[\\s\\S]*?<\\/script>/gi, '')\n      .replace(/<br\\s*\\/?>/gi, '\\n')\n      .replace(/<\\/p>/gi, '\\n')\n      .replace(/<[^>]+>/g, ' ')\n      .replace(/\\s+/g, ' ')\n      .trim();\n  }\n\n  const linkMatch = resumeText.match(/https:\\/\\/vip\\.104\\.com\\.tw\\/apply\\/ApplyResume\\?[^\\]\\s]+/);\n  if (linkMatch) {\n    resumeLink = linkMatch[0];\n    const snMatch = resumeLink.match(/sn=(\\d+)/);\n    if (snMatch) resumeId = snMatch[1];\n  }\n\n  const phoneMatch = resumeText.match(/09\\d{2}[-\\s]?\\d{3}[-\\s]?\\d{3}/);\n  if (phoneMatch) phone = phoneMatch[0];\n\n  const emailMatch = resumeText.match(/[a-zA-Z0-9._%+-]+@[a-zA-Z0-9.-]+\\.[a-z]{2,}/);\n  if (emailMatch) emailAddress = emailMatch[0];\n\n  if (email.subject) {\n    const subjectMatch = email.subject.match(/【(.+?)】/);\n    jobTitle = subjectMatch ? subjectMatch[1] : email.subject;\n  }\n\n  let contactLink = '';\n  if (phone) contactLink = `tel:${phone}`;\n  else if (emailAddress) contactLink = `mailto:${emailAddress}`;\n\n  let taiwanDate = '';\n  if (email.date) {\n    const d = new Date(email.date);\n    d.setHours(d.getHours() + 8);\n    const pad = n => String(n).padStart(2, '0');\n    taiwanDate = `${d.getUTCFullYear()}/${pad(d.getUTCMonth()+1)}/${pad(d.getUTCDate())} ${pad(d.getUTCHours())}:${pad(d.getUTCMinutes())}`;\n  }\n\n  return {\n    json: {\n      subject: email.subject || '',\n      jobTitle,\n      from: email.from || '',\n      date: taiwanDate,\n      resumeText,\n      resumeLink,\n      resumeId,\n      phone,\n      emailAddress,\n      contactLink\n    }\n  };\n});"
      },
